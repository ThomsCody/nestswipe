# PostgreSQL
POSTGRES_USER=rosen
POSTGRES_PASSWORD=rosen_secret
POSTGRES_DB=nestswipe
DATABASE_URL=postgresql+asyncpg://rosen:rosen_secret@postgres:5432/nestswipe

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=listing-photos

# JWT
JWT_SECRET=change-me-to-a-random-secret

# Google OAuth (read from oauth.json, but can be overridden)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OpenAI (set per-user in the app settings UI)
# OPENAI_API_KEY=

# Email polling interval in minutes
EMAIL_POLL_INTERVAL_MINUTES=5

# Residential proxy (optional — used to bypass bot protection on seloger.com)
# Without these, seloger scraping falls back to direct connection (may be blocked).
# PROXY_HOST=gate.decodo.com:7777
# PROXY_USER=your_username
# PROXY_PASSWORD=your_password
