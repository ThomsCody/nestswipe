# Database
POSTGRES_USER=nestswipe
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=nestswipe

# MinIO
MINIO_ROOT_USER=nestswipe-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT - generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_HEX

# Email polling interval (minutes)
EMAIL_POLL_INTERVAL_MINUTES=5

# Datadog
DD_API_KEY=<your-datadog-api-key>
